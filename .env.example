# Bu dosyayı kopyalayıp .env olarak kaydedin ve kendi API anahtarlarınızı girin.

# === SENARYO & SES & GÖRSEL (OPENAI) ===
# GPT-4o, OpenAI TTS ve DALL-E için tek anahtar
OPENAI_API_KEY=sk-buraya_kendi_anahtarinizi_yazin

# === SENARYO (GOOGLE) ===
# Google Gemini API Anahtarı (https://aistudio.google.com/apikey)
GEMINI_API_KEY=buraya_kendi_gemini_anahtarinizi_yazin

# === SENARYO (ANTHROPIC - OPSİYONEL) ===
# Claude Modelleri için (Opsiyonel)
ANTHROPIC_API_KEY=buraya_claude_anahtarini_yazin

# === SES (ELEVENLABS - PREMIUM GÜNCELLEMESİ) ===
# ElevenLabs API Anahtarı (Gerçekçi ve kaliteli Türkçe seslendirme)
ELEVENLABS_API_KEY=buraya_elevenlabs_anahtarini_yazin

# === GÖRSEL - STOK (ÜCRETSİZ, ÇOK HIZLI - ÖNERİLEN) ===
# Stock-Auto modu: Pexels → Pixabay → Unsplash → Pollinations → DALL-E sırasıyla dener
# En az 1 tanesini doldurmanız yeterli. Hepsi ücretsizdir.

# Pexels - https://www.pexels.com/api/ (Ücretsiz kayıt, 200 istek/saat)
PEXELS_API_KEY=buraya_pexels_api_anahtarinizi_yazin

# Pixabay - https://pixabay.com/api/docs/ (Ücretsiz kayıt, 5000 istek/saat)
PIXABAY_API_KEY=buraya_pixabay_api_anahtarinizi_yazin

# Unsplash - https://unsplash.com/developers (Ücretsiz kayıt, 50 istek/saat)
UNSPLASH_ACCESS_KEY=buraya_unsplash_access_key_yazin

# === GÖRSEL - AI (OPSİYONEL, YAVAŞ) ===
# Stable Diffusion veya Leonardo AI anahtarı (Alternatif görsel kalitesi için)
STABILITY_API_KEY=buraya_stability_anahtarini_yazin
LEONARDO_API_KEY=buraya_leonardo_anahtarini_yazin

# === NEDIR.ME ENTEGRASYONU ===
# WordPress site URL
WP_BASE_URL=http://localhost:8881

# WordPress API kimlik bilgileri (video durumlarını güncellemek için)
WP_USERNAME=kullanici_adiniz
WP_PASSWORD=sifreniz

# === PERFORMANS AYARLARI ===
# Maksimum eş zamanlı işlem sayısı
MAX_CONCURRENT_TASKS=4

# Önbellek boyutu (MB)
CACHE_MAX_SIZE_MB=500
